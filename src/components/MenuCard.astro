---
// Props que recibe este componente desde index.astro
const { producto } = Astro.props;
const { nombre, descripcion, precio, categoria, imagen_url } = producto;

// Formatea el precio como moneda peruana
const precioFormateado = new Intl.NumberFormat('es-PE', {
  style: 'currency',
  currency: 'PEN',
  minimumFractionDigits: 2,
}).format(precio);
---

<article class="card" data-categoria={categoria}>
  <div class="card-img-wrap">
    <img
      src={imagen_url}
      alt={nombre}
      loading="lazy"
      onerror="this.style.display='none'"
    />
  </div>

  <div class="card-body">
    <span class="categoria">{categoria}</span>
    <h2 class="nombre">{nombre}</h2>
    <p class="descripcion">{descripcion}</p>

    <div class="card-footer">
      <span class="precio">{precioFormateado}</span>
      {/* El botón "+" lo manejará el carrito en Fase 5 */}
      <button
        class="btn-agregar"
        data-id={producto.id}
        data-nombre={nombre}
        data-precio={precio}
        aria-label={`Agregar ${nombre} al carrito`}
      >
        +
      </button>
    </div>
  </div>
</article>

<style>
  .card {
    background: #fff;
    border-radius: 12px;
    border: 0.5px solid #e8e6e0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.15s, transform 0.15s;
  }
  .card:hover {
    border-color: #aaa9a0;
    transform: translateY(-2px);
  }
  .card-img-wrap {
    width: 100%;
    height: 160px;
    overflow: hidden;
    background: #f0ede6;
  }
  .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .card:hover .card-img-wrap img { transform: scale(1.04); }
  .card-body {
    padding: 14px 16px 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .categoria {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #8a8780;
    margin-bottom: 4px;
  }
  .nombre {
    font-size: 15px;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 6px;
    line-height: 1.3;
  }
  .descripcion {
    font-size: 12px;
    color: #6b6b6b;
    line-height: 1.5;
    flex: 1;
    margin-bottom: 14px;
  }
  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .precio {
    font-size: 16px;
    font-weight: 700;
    color: #1a1a1a;
  }
  .btn-agregar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #1a1a1a;
    color: #fff;
    border: none;
    cursor: pointer;
    font-size: 20px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.12s;
  }
  .btn-agregar:hover { background: #3d3d3a; }
</style>